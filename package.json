{
  "name": "make-bilibili-great-than-ever-before",
  "version": "1.8.9",
  "description": "A fork of @kookxiang's userscript \"Make Bilibili Great Again\", but with many experimental features",
  "repository": "https://github.com/SukkaW/Make-Bilibili-Great-Than-Ever-Before",
  "main": "./dist/make-bilibili-great-than-ever-before.user.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint --format=sukka .",
    "build": "rollup -c rollup.config.ts --configPlugin=swc3 --bundleConfigAsCjs",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [
    "userscript",
    "bilibili"
  ],
  "author": "SukkaW <https://skk.moe>",
  "license": "MIT",
  "dependencies": {
    "@types/tampermonkey": "^5.0.5",
    "fake-indexeddb": "^6.2.5",
    "flru": "^1.0.2",
    "foxts": "^5.4.0"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^8.9.3",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@swc/core": "^1.15.26",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^22.19.17",
    "bumpp": "^10.4.1",
    "eslint": "^10.2.1",
    "eslint-config-sukka": "^8.9.3",
    "eslint-formatter-sukka": "^8.9.3",
    "rollup": "^4.60.1",
    "rollup-plugin-swc3": "^0.12.1",
    "rollup-plugin-userscript-metablock": "^0.4.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "unrs-resolver"
    ]
  }
}
